#!/bin/bash
set -e

TF_PLAN_RAW_PATH="tf.plan"
TF_PLAN_JSON_PATH="tf.json"
DYNAMIC_TFVARS_PATH="vars/$ENV_NAME/runtime.auto.tfvars"

APP_IMAGE_TAG_VALUE="${APPLICATION_INFRA_TAG:-${APP_TAG:-${IMAGE_TAG:-}}}"

sh $WORKSPACE/ansible-vault "decrypt" "vars/$ENV_NAME/terraform-secret.tfvars"
sh $WORKSPACE/ansible-vault "decrypt" "vars/$ENV_NAME/admin_gui_session_conf"
sh $WORKSPACE/ansible-vault "decrypt" "vars/$ENV_NAME/portal_session_conf"
sh $WORKSPACE/ansible-vault "decrypt" "vars/$ENV_NAME/admin_gui_auth_conf"
sh $WORKSPACE/ansible-vault "decrypt" "vars/$ENV_NAME/tls.key"
sh $WORKSPACE/ansible-vault "decrypt" "vars/$ENV_NAME/ingress.key"
sh $WORKSPACE/ansible-vault "decrypt" "vars/$ENV_NAME/license.json"

cat > "$DYNAMIC_TFVARS_PATH" <<EOF
env_name="$ENV_NAME"
k8s_config="$K8S_CONFIG_PATH"
EOF

if [ -n "$APP_IMAGE_TAG_VALUE" ]; then
  echo "app_image_tag=\"$APP_IMAGE_TAG_VALUE\"" >> "$DYNAMIC_TFVARS_PATH"
fi

terraform plan --out $TF_PLAN_RAW_PATH -var-file=vars/$ENV_NAME/terraform-config.tfvars -var-file=./vars/$ENV_NAME/terraform-secret.tfvars -var-file="$DYNAMIC_TFVARS_PATH"
terraform show -json $TF_PLAN_RAW_PATH > $TF_PLAN_JSON_PATH

terraform graph -plan=$TF_PLAN_RAW_PATH 
