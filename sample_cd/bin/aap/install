#!/bin/bash
set -e

TERRAFORM_BACKEND_CONFIG_PATH=./terraform-backend-config

cat > $TERRAFORM_BACKEND_CONFIG_PATH <<EOF
address="https://gitlab.intra.hkma.gov.hk/api/v4/projects/$GIT_PROJECT_ID/terraform/state/$ENV_NAME"
lock_address="https://gitlab.intra.hkma.gov.hk/api/v4/projects/$GIT_PROJECT_ID/terraform/state/$ENV_NAME/lock"
unlock_address="https://gitlab.intra.hkma.gov.hk/api/v4/projects/$GIT_PROJECT_ID/terraform/state/$ENV_NAME/lock"
username="$GIT_USERNAME"
password="$GIT_PASSWORD"
lock_method="POST"
unlock_method="DELETE"
retry_wait_min="5"
EOF

TERRAFORM_ACTION="init -backend-config=$TERRAFORM_BACKEND_CONFIG_PATH -upgrade"

terraform $TERRAFORM_ACTION
